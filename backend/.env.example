# Environment variables for TranslateHub Backend
# Copy this file to .env and fill in your values

# MongoDB Connection (Required)
MONGO_URL=mongodb://localhost:27017
DB_NAME=translatehub

# CORS Origins (comma-separated list of allowed origins)
# For production, set this to your frontend URL
CORS_ORIGINS=https://your-frontend-domain.pages.dev,http://localhost:3000

# Emergent LLM Key for AI translations (Required)
# Get your key from Emergent platform
EMERGENT_LLM_KEY=your-emergent-key-here
