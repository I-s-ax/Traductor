# Environment variables for TranslateHub Frontend
# For Cloudflare Pages, set these in the dashboard

# Backend API URL (Required)
# For Clouding.io: https://api.tudominio.com
# For Render: https://translatehub-api.onrender.com
REACT_APP_BACKEND_URL=https://your-backend-url.com

# WebSocket port (only needed for local development)
WDS_SOCKET_PORT=443
